# Copy this file to docker/.env before running docker compose.
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DATABASE_URL=sqlite:///./data.db
CORS_ORIGINS=*
CF_ALLOWED_EMAILS=pg999w@gmail.com
DASHSCOPE_API_KEY=your-dashscope-key
# S3-compatible storage must be publicly reachable by Bailian.
S3_PUBLIC_ENDPOINT=https://your-public-domain
S3_REGION=auto
S3_BUCKET=transcribe
S3_SIGN_EXPIRE_SECONDS=3600
AWS_ACCESS_KEY_ID=your-ak
AWS_SECRET_ACCESS_KEY=your-sk
